# ─── DivorCEmate Email Server – Environment Variables ───
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git!

# SendGrid API Key (from sendgrid.com → Settings → API Keys)
SENDGRID_API_KEY=SG.your_api_key_here

# The verified sender email (must be verified in SendGrid → Sender Authentication)
SENDER_EMAIL=divorcematequeries@gmail.com

# The email address that receives enquiries
RECEIVER_EMAIL=divorcematequeries@gmail.com
