# ─── DivorCEmate Email Server – Environment Variables ───
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git!

# The Gmail address that SENDS the emails (acts as the mailer)
SENDER_EMAIL=divorcematequeries@gmail.com

# Gmail App Password (NOT your regular login password)
# How to get one:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (required)
#   3. Go to https://myaccount.google.com/apppasswords
#   4. App name: "DivorCEmate" → Click Create
#   5. Copy the 16-character password shown (no spaces)
SENDER_PASS=liaz gegg uwuv ehkw

# The Gmail address that RECEIVES the enquiry emails
RECEIVER_EMAIL=divorcematequeries@gmail.com

# Optional: Port for the Flask server (default: 5000)
# PORT=5000
